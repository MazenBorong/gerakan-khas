# Gerakan Khas — paste into Vercel "Import .env" after replacing placeholders.
# Generate APP_KEY locally: php artisan key:generate --show
# Set APP_URL to your deployment URL (e.g. https://gerakan-khas.vercel.app).

APP_NAME="Gerakan Khas"
APP_ENV=production
# Required — without this Laravel returns 500. Generate: php artisan key:generate --show
APP_KEY=base64:PASTE_GENERATED_KEY_HERE
APP_DEBUG=false
APP_URL=https://gk.borong.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=error
# Serverless-friendly: avoid DB sessions unless your DB is migrated and reachable
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=array
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Migrations do not run on Vercel unless you set this to 1 (needs DB + APP_KEY).
# Otherwise run once locally: php artisan migrate --force
# RUN_MIGRATE_ON_VERCEL=1
