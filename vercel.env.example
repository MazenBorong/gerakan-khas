# Gerakan Khas — paste into Vercel "Import .env" after replacing placeholders.
# Generate APP_KEY locally: php artisan key:generate --show
# Set APP_URL to your deployment URL (e.g. https://gerakan-khas.vercel.app).

APP_NAME="Gerakan Khas"
APP_ENV=production
APP_KEY=base64:PASTE_GENERATED_KEY_HERE
APP_DEBUG=false
APP_URL=https://YOUR_PROJECT.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Managed MySQL / Postgres (use your provider’s host, DB name, user, password)
DB_CONNECTION=mysql
DB_HOST=YOUR_DB_HOST
DB_PORT=3306
DB_DATABASE=YOUR_DB_NAME
DB_USERNAME=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD

# Serverless-friendly: avoid DB sessions unless your DB is migrated and reachable
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=array
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
